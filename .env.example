# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Required: article text generation (https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required for image generation (https://platform.openai.com/api-keys)
# Use --no-image to skip image generation entirely.
OPENAI_API_KEY=your-openai-api-key-here
